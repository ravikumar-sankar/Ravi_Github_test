{
  "name": "ravi-github-test",
  "version": "0.1.0",
  "private": true,
  "description": "Sandbox repository scaffold for GitHub workflows and CI/CD",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ test/ --ext .ts",
    "lint:fix": "eslint src/ test/ --ext .ts --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "format": "prettier --write .",
    "start:dev": "ts-node src/index.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
