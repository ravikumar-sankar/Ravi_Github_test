{
  "name": "ravi-github-test",
  "version": "0.1.0",
  "private": true,
  "description": "Sandbox repository scaffold for GitHub workflows and CI/CD",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ test/ --ext .ts --max-warnings 0",
    "lint:fix": "eslint src/ test/ --ext .ts --fix --max-warnings 0",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "format": "prettier --write .",
    "prepare": "husky",
    "start:dev": "ts-node src/index.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.ts": ["eslint --fix", "prettier --write"]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
